configuration {
	modes: "window,drun,run,ssh";
	font: "mono 24";
	show-icons: true;
	hover-select: false;
  timeout {
      action: "kb-cancel";
      delay:  0;
  }
  filebrowser {
      directories-first: true;
      sorting-method:    "name";
  }
}

@theme "/usr/share/rofi/themes/Adapta-Nokto.rasi"
